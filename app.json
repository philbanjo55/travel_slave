{
  "expo": {
    "name": "Philm+Frame",
    "slug": "travelslave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.philmframe.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "config": {}
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Philm+Frame to access your photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Philm+Frame to use your location for navigation."
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "766c58f8-02a0-4ba7-8426-2fb86227bdec"
      }
    },
    "owner": "philandframe",
    "updates": {
      "url": "https://u.expo.dev/766c58f8-02a0-4ba7-8426-2fb86227bdec",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}